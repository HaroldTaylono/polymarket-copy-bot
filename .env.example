# Polymarket CLOB client. POLYMARKET_PRIVATE_KEY is required in both test and live modes.
POLYMARKET_CLOB_HOST=https://clob.polymarket.com
POLYMARKET_CHAIN_ID=137
POLYMARKET_SIGNATURE_TYPE=POLY_1271
POLYGON_RPC_URL=https://polygon-rpc.com

# EOA Private Key: Export from wallets such as MetaMask
POLYMARKET_PRIVATE_KEY=0x
# Wallet address: Located at `https://polymarket.com/settings?tab=profile`
POLYMARKET_DEPOSIT_WALLET=0xYOUR_POLYMARKET_DEPOSIT_WALLET

# Optional: reuse CLOB L2 credentials. If omitted, the bot derives them from the private key.
CLOB_API_KEY=
CLOB_SECRET=
CLOB_PASS_PHRASE=

# Public read API.
DATA_API_BASE_URL=https://data-api.polymarket.com

# Comma-separated trader / proxy wallet addresses to follow.
WATCHED_WALLETS=0x1111111111111111111111111111111111111111,0x2222222222222222222222222222222222222222

# Polling. npm run test defaults to one poll; npm start defaults to continuous mode.
POLL_INTERVAL_MS=15000
START_LOOKBACK_MINUTES=30
ACTIVITY_PAGE_SIZE=50
RUN_ONCE=

# Copy sizing: fixed or percentage.
COPY_MODE=fixed
FIXED_BUY_AMOUNT_USD=5
FIXED_SELL_AMOUNT_USD=5
COPY_PERCENTAGE=0.10

# Market order behavior. FAK allows partial fill; FOK requires full fill.
ORDER_TYPE=FAK

# Optional price protection around the followed fill price.
# 0 lets the CLOB client estimate the marketable worst price.
PRICE_PROTECTION_BPS=0

# Risk controls
MIN_ORDER_USD=1
MAX_ORDER_USD=25
MAX_POSITION_USD_PER_TOKEN=100
DAILY_MAX_NOTIONAL_USD=250

# Local state
DATA_DIR=./data
STATE_FILE=state.json
